# === BOT CONFIGURATION ===
BOT_TOKEN=your_bot_token_here
BOT_USERNAME=PipBot

# === DATABASE ===
# SQLite (default, no setup needed):
DATABASE_URL=sqlite+aiosqlite:///pipbot.db
# PostgreSQL (uncomment to use):
# DATABASE_URL=postgresql+asyncpg://user:password@localhost/pipbot

# === REDIS (optional) ===
REDIS_URL=redis://localhost:6379/0
USE_REDIS=false

# === OPENAI (optional, for toxicity detection) ===
OPENAI_API_KEY=
USE_OPENAI=false

# === LOGGING ===
LOG_LEVEL=INFO
LOG_FILE=logs/pipbot.log

# === ADMINS ===
# Your Telegram user ID (find via @userinfobot)
SUPER_ADMINS=123456789

# === SETTINGS ===
DEFAULT_LANG=ru
DAILY_REPORT_TIME=09:00
